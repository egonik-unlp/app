{
  "name": "spotify-pathfinder-visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build:wasm": "wasm-pack build worker-core --target web --release --out-dir pkg",
    "build:snapshot": "server/.venv/bin/python tools/build_snapshot.py",
    "build": "npm run build:wasm && tsc -b && vite build",
    "cf:dev": "npm run build && wrangler dev",
    "cf:deploy": "npm run build && wrangler deploy",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@react-three/drei": "^10.2.0",
    "@react-three/fiber": "^9.1.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250610.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.177.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.7.2",
    "vite": "^8.1.0",
    "wrangler": "^4.104.0"
  }
}
