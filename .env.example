# Spotify (required). For deploy, set these as Worker secrets instead:
#   wrangler secret put SPOTIFY_CLIENT_ID
#   wrangler secret put SPOTIFY_CLIENT_SECRET
# For local `wrangler dev`, copy them into .dev.vars (gitignored).
#
# "Save journey as playlist" uses browser-side OAuth (PKCE) with the public
# CLIENT_ID. In the Spotify app dashboard, add the app origin(s) as Redirect
# URIs, e.g. http://127.0.0.1:8787/ (dev) and https://<your-worker>.workers.dev/.
# (Sample playback uses the iTunes Search API, not Spotify — needs no setup.)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---- offline snapshot build only (tools/build_snapshot.py) ----
# Where the corpus is read from to bake public/data/corpus.bin. Not used at runtime.
QDRANT_URL=http://localhost:6335
PATHFINDER_COLLECTION=spotify_tracks_song_ae

# ---- cold-start projector (optional; tools/build_snapshot.py --projector) ----
# Used at BUILD time to embed corpus text with the same model the Worker uses at
# runtime (@cf/baai/bge-m3), so the projector matches. Get these from the
# Cloudflare dashboard (Workers AI). Leave blank to ship corpus-only.
CF_ACCOUNT_ID=
CF_AI_TOKEN=
